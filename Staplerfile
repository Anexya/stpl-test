# === SFE-249 compliant Staplerfile for hello-world ===

sfe_249_new_extractor=1

name="hello-world"
version="1.0.0"
release="1"
summary="Simple Hello World program"
summary_ru="Простая программа Hello World"
group="Development/Tools"
desc="$summary. Outputs 'Hello, World!' to stdout."
desc_ru="$summary_ru. Выводит 'Hello, World!' в стандартный вывод."
maintainer="Anexya <anexya@example.ru>"
architectures=("x86_64")
homepage="https://github.com/Anexya"
license=("MIT")

# === Зависимости ===
deps_altlinux_sisyphus=()

# === Источники ===
# Так как наша программа простая, мы не скачиваем ничего извне
# sources=() # Не используется

# === Контрольные суммы ===
# checksums=() # Не используется

# === Функции сборки ===
prepare() {
    echo "Preparing hello-world package..."
}

build() {
    echo "Building hello-world package..."
    # Ничего не собираем, просто копируем файл
}

package() {
    # Установка файлов в пакет
    mkdir -p "$pkgdir/usr/bin"

    # Копируем исполняемый файл
    cp hello-world "$pkgdir/usr/bin/hello-world"
    chmod +x "$pkgdir/usr/bin/hello-world"
		}

		files() {
		    files-find-binary hello-world
		    files-find "/usr/bin/hello-world"
		}
