# === Метаданные пакета ===
name = "hello-world"
version = "1.0.0"
release = "1"
summary = "Simple Hello World program"
desc = """A classic Hello World program.
This package demonstrates basic package creation with Stapler."""
group = "Development/Tools"
license = ["MIT"]
maintainer = "Anexya <is.petrov@vk.com>"
homepage = "https://github.com/Anexya"

# === Зависимости ===
# Нет зависимостей — наша программа использует только bash
deps_altlinux = []

# === Источники ===
# Мы не скачиваем ничего из интернета — создаём программу локально
# sources = []  # Не нужно, так как файлы уже есть

# === Функции сборки ===
prepare() {
    # Подготовка — здесь ничего не нужно
    echo "Preparing hello-world package..."
}

build() {
    # Сборка — тоже не нужна, так как наша программа готова
    echo "Building hello-world package..."
}

package() {
    # Установка файлов в пакет
    # $pkgdir — временная директория, куда Stapler копирует файлы
    
    # Создаём директорию для бинарников
    mkdir -p "$pkgdir/usr/bin"
    
#Копируем нашу программу
    cp hello-world "$pkgdir/usr/bin/hello-world"
    
    # Делаем её исполняемой
    chmod +x "$pkgdir/usr/bin/hello-world"
    
    # Создаём директорию для документации
    mkdir -p "$pkgdir/usr/share/doc/hello-world"
    
    # Создаём файл README
    cat > "$pkgdir/usr/share/doc/hello-world/README"
# Hello World Package

This package contains a simple "Hello, World!" program.

## Usage

Run the program:
```bash
hello-world
