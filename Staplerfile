# Имя пакета (должно совпадать с именем директории)
name='hello-world'

# Версия программы (указываем свою, например 1.0)
version='1.0'

# Релиз для наших сборок (начинаем с 1)
release='1'

# Краткое описание
summary='A simple "Hello, World!" shell script'

# Полное описание
desc='This package provides a classic example script that prints "Hello, World!" to the console.'

# Домашняя страница (можно оставить пустым или указать заглушку)
homepage='https://github.com/Anexya/stpl-test/tree/main'

# Поддерживающий (ваши данные)
maintainer='Anexya <petrossikk@rambler.ru>'

# Группа пакета для RPM (одна из стандартных)
group='System/Base'

# Поддерживаемые архитектуры (скрипт не зависит от архитектуры)
architectures=('all')

# Лицензия (укажите подходящую, например MIT)
license=('MIT')

# Исходные файлы. Сам скрипт должен лежать рядом со Staplerfile.
# Используем протокол local:// для локальных файлов.
sources=(
    'local://hello-world.sh'
)

# Контрольная сумма (пропускаем проверку для локального простого файла,
# но в реальном проекте лучше вычислить sha256 и указать её)
checksums=('SKIP')

# Основная функция сборки. Для простого скрипта она не нужна.
build() {
    # Ничего не делаем, так как исходный файл — уже готовый скрипт
    true
}

# Функция упаковки. Здесь мы устанавливаем файлы в $pkgdir.
package() {
    # Создаём нужную директорию в виртуальной корневой файловой системе пакета
    install -dm755 "${pkgdir}/usr/bin"
    
    # Устанавливаем наш скрипт с правами на исполнение
    # install -Dm755 <что> <куда>
    install -Dm755 "${srcdir}/hello-world.sh" "${pkgdir}/usr/bin/hello-world"
    
    # Альтернатива с использованием вспомогательной команды:
    # install-binary "${srcdir}/hello-world.sh" "hello-world"
}

# Вспомогательная функция для указания всех файлов пакета (для корректного удаления в RPM)
files() {
    # Указываем, что в пакете есть бинарник в /usr/bin
    files-find-binary "hello-world"
}
